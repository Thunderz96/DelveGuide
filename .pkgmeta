package-as: DelveGuide

ignore:
  - .github
  - .gitignore
  - .pkgmeta
  - .claude
  - CHANGELOG.md
  - LICENSE
  - README.md

externals:
  Libs/LibStub: https://github.com/Stanzilla/LibStub
  Libs/CallbackHandler-1.0: https://repos.curseforge.com/wow/callbackhandler
  Libs/LibDataBroker-1.1: https://github.com/tekkub/libdatabroker-1-1
  Libs/LibDBIcon-1.0: https://repos.curseforge.com/wow/libdbicon-1-0

enable-nolib-creation: no
