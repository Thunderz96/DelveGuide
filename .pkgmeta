package-as: DelveGuide

ignore:
  - .github
  - .gitignore
  - .pkgmeta
  - .claude
  - CHANGELOG.md
  - LICENSE
  - README.md

# Libraries are committed under Libs/ and packaged as-is. No externals
# fetched at build time -- the previous URLs (CurseForge git mirrors and
# Stanzilla/LibStub) all 404, and the repo already contains working copies
# of LibStub, CallbackHandler-1.0, LibDataBroker-1.1, and LibDBIcon-1.0.

enable-nolib-creation: no
